// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Prisma schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum OrganizationRole {
  OWNER
  MANAGER
  BUYER
}

enum RequestStatus {
  DRAFT
  SUBMITTED
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
  PAID
  DELIVERED
  SUSPENDED
  CANCELLED
}

enum LeadStatus {
  LOCKED
  AVAILABLE
  DELIVERED
  REJECTED
  REPLACED
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
}

enum LeadDeliveryChannel {
  EMAIL
  CSV_EXPORT
  API
  MANUAL
}

enum LeadDeliveryStatus {
  PENDING
  SENT
  FAILED
}

enum DeliveryCadence {
  REAL_TIME
  DAILY_BATCH
  WEEKLY_BATCH
}

enum VolumeCadence {
  DAY
  WEEK
  MONTH
}

enum RecurrenceCadence {
  NONE
  WEEKLY
  MONTHLY
}

enum DisputeStatus {
  PENDING_REVIEW
  ACCEPTED
  REJECTED
}

enum NotificationType {
  CAMPAIGN_APPROVED
  QUOTA_NEAR_LIMIT
  BUDGET_LOW
  LEADS_DELAYED
  QUALITY_BELOW_THRESHOLD
  LEAD_DELIVERED
  CAMPAIGN_EXPIRED
  CAMPAIGN_SUSPENDED
  ACTION_REQUIRED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  OVERDUE
}

model User {
  id           String   @id @default(cuid())
  firstName    String
  lastName     String
  email        String   @unique
  passwordHash String
  phone        String?
  city         String?
  role         UserRole @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  requests Request[]
  orders   Order[]
  leads    Lead[]
  disputes LeadDispute[]
  organizationMemberships OrganizationMember[]
  createdRequests         Request[] @relation("RequestCreatedBy")
  approvedRequests        Request[] @relation("RequestApprovedBy")
  notifications           Notification[]
  auditLogs               AuditLog[]
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members       OrganizationMember[]
  requests      Request[]
  notifications Notification[]
  auditLogs     AuditLog[]
  invoices      Invoice[]
}

model OrganizationMember {
  id             String           @id @default(cuid())
  organizationId String
  userId         String
  role           OrganizationRole @default(BUYER)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
}

model Request {
  id                      String            @id @default(cuid())
  userId                  String
  organizationId          String?
  createdByUserId         String?
  approvedByUserId        String?
  campaignName            String
  needType                String
  requestedLeads          Int
  age                     Int
  situation               String
  coverageLevel           String
  geoArea                 String
  targetSegment           String
  qualityLevel            String
  isExclusive             Boolean           @default(false)
  startDate               DateTime?
  campaignDurationDays    Int?
  budget                  Int
  maxPricePerLead         Int
  volumeCadence           VolumeCadence     @default(MONTH)
  volumePerCadence        Int
  targetAgeMin            Int?
  targetAgeMax            Int?
  familySituation         String?
  professionalStatus      String?
  incomeLevel             String?
  currentContractType     String?
  contractExpiryDate      DateTime?
  immediateNeed           Boolean?
  preferredContactChannel String?
  phoneRequired           Boolean           @default(true)
  emailRequired           Boolean           @default(true)
  alreadyInsured          Boolean?
  customerType            String?
  deliveryCadence         DeliveryCadence   @default(REAL_TIME)
  deliveryByEmail         Boolean           @default(false)
  deliveryByWebhook       Boolean           @default(false)
  deliveryByApi           Boolean           @default(false)
  deliveryByCsv           Boolean           @default(false)
  deliveryToCrm           Boolean           @default(false)
  instantNotifications    Boolean           @default(true)
  autoPauseOnQuota        Boolean           @default(true)
  deliveryHours           String?
  quotaRequested          Int
  quotaConsumed           Int               @default(0)
  dailyLimit              Int?
  monthlyLimit            Int?
  autoStopAtQuota         Boolean           @default(true)
  autoResumeOnRecharge    Boolean           @default(false)
  rolloverUnusedQuota     Boolean           @default(false)
  isTemplate              Boolean           @default(false)
  templateName            String?
  sourceRequestId         String?
  isRecurring             Boolean           @default(false)
  recurrenceCadence       RecurrenceCadence @default(NONE)
  nextRenewalDate         DateTime?
  notes                   String?
  status                  RequestStatus     @default(DRAFT)
  refusalReason           String?
  alternativeProposal     String?
  counterProposalVolume   Int?
  counterProposalPrice    Int?
  estimatedAvailableVolume Int?
  estimatedDaysToQuota    Int?
  segmentTensionScore     Int?
  feasibilityScore        Int?
  recommendation          String?
  budgetAlert             Boolean           @default(false)
  zoneAlert               Boolean           @default(false)
  suggestedCriteria       String?
  leadsDelivered          Int               @default(0)
  leadsAccepted           Int               @default(0)
  leadsRejected           Int               @default(0)
  totalCost               Int               @default(0)
  avgCostPerLead          Int               @default(0)
  deliverySpeedPerDay     Float             @default(0)
  contactRate             Float             @default(0)
  declaredConversionRate  Float             @default(0)
  estimatedRoi            Float             @default(0)
  segmentPerformance      String?
  walletCredit            Int               @default(0)
  autoRechargeEnabled     Boolean           @default(false)
  budgetLowThreshold      Int?
  budgetLowAlertSent      Boolean           @default(false)
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  createdBy  User?         @relation("RequestCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  approvedBy User?         @relation("RequestApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  order     Order?
  leads     Lead[]
  disputes  LeadDispute[]
  invoiceItems InvoiceItem[]

  @@index([userId])
  @@index([status])
  @@index([sourceRequestId])
  @@index([organizationId])
}

model Order {
  id              String        @id @default(cuid())
  userId          String
  requestId       String        @unique
  stripeSessionId String        @unique
  amount          Int
  paymentStatus   PaymentStatus @default(PENDING)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  request Request @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([paymentStatus])
}

model Lead {
  id           String     @id @default(cuid())
  requestId    String
  userId       String
  title        String
  description  String
  contactName  String
  contactEmail String
  contactPhone String
  status       LeadStatus @default(LOCKED)
  deliveredAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  request Request @relation(fields: [requestId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries LeadDelivery[]
  disputes LeadDispute[]

  @@index([requestId])
  @@index([userId])
  @@index([status])
}

model LeadDispute {
  id                String       @id @default(cuid())
  leadId             String
  requestId          String
  userId             String
  reason             String
  details            String?
  status             DisputeStatus @default(PENDING_REVIEW)
  resolutionComment  String?
  replacementLeadId  String?
  createdAt          DateTime     @default(now())
  resolvedAt         DateTime?

  lead    Lead    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  request Request @relation(fields: [requestId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([requestId])
  @@index([userId])
  @@index([status])
}

model Partner {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String?
  city      String?
  deliveryWebhookUrl String?
  apiEndpoint String?
  apiKey      String?
  csvEmail    String?
  crmWebhookUrl String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deliveries LeadDelivery[]

  @@index([isActive])
}

model Notification {
  id             String           @id @default(cuid())
  userId         String
  organizationId String?
  type           NotificationType
  title          String
  message        String
  isRead         Boolean          @default(false)
  requestId      String?
  createdAt      DateTime         @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([organizationId])
  @@index([isRead])
}

model AuditLog {
  id             String   @id @default(cuid())
  userId         String
  organizationId String?
  action         String
  targetType     String
  targetId       String
  details        String?
  createdAt      DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([organizationId])
  @@index([targetType, targetId])
}

model Invoice {
  id             String        @id @default(cuid())
  organizationId String
  periodMonth    Int
  periodYear     Int
  status         InvoiceStatus @default(DRAFT)
  totalAmount    Int           @default(0)
  issuedAt       DateTime?
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  items        InvoiceItem[]

  @@unique([organizationId, periodMonth, periodYear])
  @@index([organizationId])
  @@index([status])
}

model InvoiceItem {
  id        String   @id @default(cuid())
  invoiceId String
  requestId String
  amount    Int
  quantity  Int      @default(1)
  unitPrice Int
  createdAt DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  request Request @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([requestId])
}

model LeadDelivery {
  id        String             @id @default(cuid())
  leadId    String
  partnerId String
  channel   LeadDeliveryChannel @default(EMAIL)
  status    LeadDeliveryStatus @default(PENDING)
  sentAt    DateTime?
  notes     String?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  lead    Lead    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([partnerId])
  @@index([status])
}
